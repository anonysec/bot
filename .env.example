# .env.example
# Panel Configuration
PANEL_URL=https://your-panel.com
PANEL_USERNAME=admin
PANEL_PASSWORD=your-password
PANEL_PROXY=socks5://proxy:1080
INBOUND_ID=1

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_PROXY=socks5://proxy:1080

# Database
DATABASE_URL=sqlite:///vpn_bot.db

# Web App
SECRET_KEY=your-secret-key-here
WEB_HOST=0.0.0.0
WEB_PORT=5000

# Payment Gateways - Optional (set ENABLED=true to enable each one)
PAYMENT_ENABLED=true

# Zarinpal (https://zarinpal.com)
ZARINPAL_ENABLED=false
ZARINPAL_MERCHANT_ID=

# Pay.ir (https://pay.ir)
PAYIR_ENABLED=false
PAYIR_API_KEY=

# IDPay (https://idpay.ir)
IDPAY_ENABLED=false
IDPAY_API_KEY=

# Tetra (https://tetra98.com/docs)
TETRA_ENABLED=false
TETRA_API_KEY=

# Admin IDs (comma-separated)
ADMIN_IDS=123456789,987654321

# Trial Config Settings
TRIAL_DURATION_HOURS=2
TRIAL_TRAFFIC_LIMIT=1
TRIAL_TRAFFIC_UNIT=GB

# Referral System
REFERRAL_COMMISSION_PERCENT=10

# Traffic Alert
TRAFFIC_ALERT_GB=1