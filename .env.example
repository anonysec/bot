# .env.example
# Panel Configuration
PANEL_URL=https://your-panel.com
PANEL_USERNAME=admin
PANEL_PASSWORD=your-password
PANEL_PROXY=socks5://proxy:1080
INBOUND_ID=1

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_PROXY=socks5://proxy:1080

# Database
DATABASE_URL=sqlite:///vpn_bot.db

# Web App
SECRET_KEY=your-secret-key-here
WEB_HOST=0.0.0.0
WEB_PORT=5000

# Payment Gateways - Tetra only
PAYMENT_ENABLED=true

# Tetra (https://tetra98.com/docs) - TON/TRON/Card to Card
TETRA_ENABLED=false
TETRA_API_KEY=

# Admin IDs (comma-separated)
ADMIN_IDS=123456789,987654321

# Trial Config Settings
TRIAL_DURATION_HOURS=2
TRIAL_TRAFFIC_LIMIT=1
TRIAL_TRAFFIC_UNIT=GB

# Referral System
REFERRAL_COMMISSION_PERCENT=10

# Traffic Alert
TRAFFIC_ALERT_GB=1